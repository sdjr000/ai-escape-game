# ============================================================
# 微信分享配置（微信分享功能需要）
# 复制此文件为 .env.local 并填入真实值
# ============================================================

# 微信公众平台 AppID（服务号，需要微信认证）
WECHAT_APP_ID=

# 微信公众平台 AppSecret
WECHAT_APP_SECRET=

# ============================================================
# OpenAI API 配置（可选，用于增强AI对话质量）
# 不配置则使用内置本地回复引擎
# ============================================================

# OpenAI API Key
# OPENAI_API_KEY=

# OpenAI 模型（默认 gpt-4）
# OPENAI_MODEL=gpt-4
